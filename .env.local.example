# Copiez ce fichier en .env.local et remplissez vos valeurs

# Google OAuth Credentials
# Créez vos credentials sur: https://console.cloud.google.com/apis/credentials
# 1. Créez un projet
# 2. Activez l'API Gmail
# 3. Créez des identifiants OAuth 2.0 (Application Web)
# 4. Ajoutez http://localhost:3000/api/auth/callback comme URI de redirection autorisée
GOOGLE_CLIENT_ID=votre_google_client_id
GOOGLE_CLIENT_SECRET=votre_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Microsoft / Outlook OAuth Credentials
# Créez votre app sur: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# 1. Créez une "New registration" (Web, redirect URI: http://localhost:3000/api/auth/outlook/callback)
# 2. Créez un "Client secret" dans "Certificates & secrets"
# 3. Activez les permissions: Mail.Read, Mail.Send, Mail.ReadWrite, User.Read
MICROSOFT_CLIENT_ID=votre_microsoft_client_id
MICROSOFT_CLIENT_SECRET=votre_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/outlook/callback

# Anthropic Claude API Key
# Obtenez votre clé sur: https://console.anthropic.com/
ANTHROPIC_API_KEY=votre_cle_anthropic

# GoHighLevel API (optionnel - l'app fonctionne sans)
# Obtenez votre clé dans: GHL > Paramètres > Clés API
GHL_API_KEY=votre_cle_ghl
GHL_LOCATION_ID=votre_location_id_ghl

# URL de l'application
NEXTAUTH_URL=http://localhost:3000
